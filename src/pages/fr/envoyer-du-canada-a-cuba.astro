---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { cities } from '../../data/cities';

const alternates = [
  { hreflang: 'en', href: 'https://boxtocuba.ca/ship-from-canada-to-cuba/' },
  { hreflang: 'es', href: 'https://boxtocuba.ca/es/enviar-desde-canada-a-cuba/' },
  { hreflang: 'fr', href: 'https://boxtocuba.ca/fr/envoyer-du-canada-a-cuba/' },
  { hreflang: 'x-default', href: 'https://boxtocuba.ca/ship-from-canada-to-cuba/' },
];

const provinceOrder = [
  'Ontario',
  'Québec',
  'Colombie-Britannique',
  'Alberta',
  'Manitoba',
  'Nouvelle-Écosse',
];

const citiesByProvince = provinceOrder.map((province) => ({
  province,
  cities: cities.filter((c) => c.province_fr === province),
})).filter((g) => g.cities.length > 0);
---

<BaseLayout
  lang="fr"
  title="Envoi du Canada vers Cuba | Toutes les villes | Box to Cuba"
  description="Expédiez des colis depuis n'importe quelle ville du Canada vers Cuba. Box to Cuba offre des vols hebdomadaires, livraison porte-à-porte à La Havane, point de retrait dans les autres provinces, et les mêmes tarifs abordables depuis Toronto, Montréal, Vancouver, Calgary et plus."
  alternates={alternates}
>
  <Navbar lang="fr" />

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100 px-6 py-3">
    <div class="max-w-5xl mx-auto text-sm text-gray-400">
      <a href="/fr/" class="hover:text-red-500 transition-colors">Accueil</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">Envoyer du Canada vers Cuba</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-white to-red-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-500 text-xs font-semibold px-4 py-2 rounded-full mb-5">
        ✈️ Vols hebdomadaires du Canada vers Cuba
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Envoyer du Canada vers Cuba
      </h1>
      <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-8">
        Box to Cuba expédie des colis depuis des villes de tout le Canada vers Cuba chaque semaine. Mêmes tarifs abordables — livraison porte-à-porte à La Havane, point de retrait dans les autres provinces — peu importe où vous êtes au Canada.
      </p>
      <div class="flex gap-3 flex-wrap">
        <a href="https://app.boxtocuba.ca/shipping-quote?lang=fr" class="px-6 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-colors">Obtenir un devis →</a>
        <a href="https://wa.me/14168365517" class="px-6 py-3 border border-gray-200 font-semibold rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- QUICK STATS -->
  <section class="border-b border-gray-100 px-6 py-8">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center">
        <div class="text-2xl font-extrabold text-red-500">Dès $6/lb</div>
        <div class="text-xs text-gray-400 mt-1">Tarif de départ</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">Hebdo</div>
        <div class="text-xs text-gray-400 mt-1">Vols vers Cuba</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">{cities.length} villes</div>
        <div class="text-xs text-gray-400 mt-1">Partout au Canada</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">16</div>
        <div class="text-xs text-gray-400 mt-1">Provinces couvertes</div>
      </div>
    </div>
  </section>

  <!-- CITIES BY PROVINCE -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Villes desservies</div>
      <h2 class="text-3xl font-extrabold mb-10">Sélectionnez votre ville</h2>

      <div class="space-y-10">
        {citiesByProvince.map(({ province, cities: provinceCities }) => (
          <div>
            <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4">{province}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
              {provinceCities.map((c) => (
                <a
                  href={`/fr/envoyer-de-${c.slug}-a-cuba/`}
                  class="flex items-center justify-between px-5 py-4 bg-white rounded-xl border border-gray-100 shadow-sm hover:border-red-300 hover:shadow-md transition-all group"
                >
                  <div>
                    <div class="font-semibold text-gray-800 group-hover:text-red-500 transition-colors">{c.name}</div>
                    <div class="text-xs text-gray-400 mt-0.5">{c.province_fr}</div>
                  </div>
                  <span class="text-red-400 text-lg">→</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-gray-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Comment ça marche</div>
      <h2 class="text-3xl font-extrabold mb-10">Envoyer du Canada vers Cuba en 4 étapes</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          ['📦', 'Emballez vos articles', 'Emballez ce que vous souhaitez envoyer et obtenez un devis gratuit sur app.boxtocuba.ca.'],
          ['🚚', 'Envoyez à notre hub de Toronto', 'Déposez à notre bureau de Scarborough ou expédiez vos boîtes via Postes Canada, Purolator ou tout service de messagerie.'],
          ['✈️', 'Vol hebdomadaire vers Cuba', 'Nous consolidons et expédions votre envoi vers Cuba chaque semaine — la douane est gérée par nous.'],
          ['🏠', 'Livraison à Cuba incluse', 'Porte-à-porte à La Havane ; point de retrait dans les autres provinces.'],
        ].map(([icon, title, desc]) => (
          <div class="bg-white rounded-2xl border border-gray-100 p-6 flex gap-4 items-start shadow-sm">
            <span class="text-3xl">{icon}</span>
            <div>
              <div class="font-bold text-gray-800 mb-1">{title}</div>
              <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white text-center py-20 px-6">
    <h2 class="text-3xl font-extrabold mb-3">Prêt à envoyer depuis le Canada?</h2>
    <p class="opacity-80 mb-8">Obtenez un devis instantané — sans inscription.</p>
    <a href="https://app.boxtocuba.ca/shipping-quote?lang=fr" class="inline-block px-8 py-4 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors text-lg">Calculer mon tarif →</a>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 px-6 py-12">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="font-bold text-white text-lg mb-2">Box to Cuba</div>
        <p class="text-sm">Envoi fiable de colis du Canada vers Cuba. La confiance des familles depuis 2020.</p>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Liens rapides</div>
        <ul class="space-y-2 text-sm">
          <li><a href="/fr/tarifs-envoi-canada-cuba" class="hover:text-red-400 transition-colors">Tarifs</a></li>
          <li><a href="/fr/guide-douanes-cuba" class="hover:text-red-400 transition-colors">Guide douanes</a></li>
          <li><a href="/fr/#faq" class="hover:text-red-400 transition-colors">FAQ</a></li>
          <li><a href="/fr/#contact" class="hover:text-red-400 transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Contact</div>
        <ul class="space-y-2 text-sm">
          <li><a href="tel:+14168365517" class="hover:text-red-400 transition-colors">📞 +1 416-836-5517</a></li>
          <li><a href="mailto:info@boxtocuba.ca" class="hover:text-red-400 transition-colors">✉️ info@boxtocuba.ca</a></li>
          <li><a href="https://wa.me/14168365517" target="_blank" rel="noopener" class="hover:text-green-400 transition-colors">💬 WhatsApp</a></li>
          <li>📍 Toronto et Montréal, Canada</li>
        </ul>
      </div>
    </div>
    <div class="max-w-5xl mx-auto mt-10 pt-6 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <span>© 2026 Box to Cuba. Tous droits réservés.</span>
      <span>Politique de confidentialité · Conditions d'utilisation</span>
    </div>
  </footer>
</BaseLayout>
