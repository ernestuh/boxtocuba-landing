---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  { q: 'Are prices in Canadian or US dollars?', a: 'All our prices are in Canadian dollars (CAD). We accept cash and Interac e-Transfer.' },
  { q: 'Can I send multiple boxes to different destinations in Cuba?', a: 'Yes. Each box can have a different recipient. Each box is quoted based on its weight and destination province.' },
  { q: 'Are there volume discounts?', a: 'Yes, we offer special rates for frequent customers and high-volume shipments. Contact us to discuss a customized plan.' },
  { q: 'Does the price include delivery in Cuba?', a: 'Yes, delivery in Cuba is included in the rate. The method (door-to-door or pickup point) depends on the province — our team will confirm at the time of booking.' },
  { q: 'When do I pay?', a: 'Payment is made when you drop off or schedule pickup of your package. No advance online payment required.' },
];

const provinces = [
  { name: 'La Habana', price: 'From $6/lb', time: '7–12 business days', note: 'Most frequent flights' },
  { name: 'Artemisa', price: 'From $6/lb', time: '7–14 business days', note: '—' },
  { name: 'Mayabeque', price: 'From $6/lb', time: '7–14 business days', note: '—' },
  { name: 'Matanzas', price: 'From $6.50/lb', time: '10–15 business days', note: 'Includes Varadero' },
  { name: 'Villa Clara', price: 'From $6.50/lb', time: '10–15 business days', note: '—' },
  { name: 'Cienfuegos', price: 'From $7/lb', time: '10–16 business days', note: '—' },
  { name: 'Sancti Spíritus', price: 'From $7/lb', time: '10–16 business days', note: '—' },
  { name: 'Ciego de Ávila', price: 'From $7/lb', time: '12–17 business days', note: '—' },
  { name: 'Camagüey', price: 'From $7.50/lb', time: '12–17 business days', note: '—' },
  { name: 'Las Tunas', price: 'From $7.50/lb', time: '12–18 business days', note: '—' },
  { name: 'Holguín', price: 'From $7.50/lb', time: '12–18 business days', note: '—' },
  { name: 'Granma', price: 'From $8/lb', time: '14–20 business days', note: '—' },
  { name: 'Santiago de Cuba', price: 'From $8/lb', time: '14–20 business days', note: "Cuba's second largest city" },
  { name: 'Guantánamo', price: 'From $8/lb', time: '14–20 business days', note: '—' },
  { name: 'Pinar del Río', price: 'From $6.50/lb', time: '10–15 business days', note: '—' },
  { name: 'Isla de la Juventud', price: 'Inquire', time: 'Variable', note: 'Special transport required' },
];
---

<BaseLayout
  lang="en"
  title="Canada to Cuba Shipping Rates 2026 | Box to Cuba"
  description="Shipping rates to all Cuban provinces from Canada. No hidden fees. From $6/lb. Get your quote in seconds."
  faqItems={faqItems}
>

  <!-- NAVBAR -->
  <nav class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <img src="/logo.png" alt="Box to Cuba" class="w-10 h-10 object-contain" />
        <span class="font-bold text-gray-900 text-lg">Box to Cuba</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/#services" class="text-gray-500 hover:text-red-500 text-sm transition-colors">Services</a>
        <a href="/#how-it-works" class="text-gray-500 hover:text-red-500 text-sm transition-colors">How it Works</a>
        <a href="/#destinations" class="text-gray-500 hover:text-red-500 text-sm transition-colors">Destinations</a>
        <a href="/canada-to-cuba-shipping-rates" class="text-red-500 font-semibold text-sm border-b-2 border-red-500 pb-0.5">Rates</a>
        <a href="/#faq" class="text-gray-500 hover:text-red-500 text-sm transition-colors">FAQ</a>
      </div>
      <div class="flex items-center gap-2">
        <a href="/es/precios-envio-canada-cuba" class="text-xs text-gray-400 hover:text-red-500 px-2 py-1 rounded transition-colors">ES</a>
        <a href="/fr/tarifs-envoi-canada-cuba" class="text-xs text-gray-400 hover:text-red-500 px-2 py-1 rounded transition-colors">FR</a>
        <a href="https://app.boxtocuba.ca/client" class="px-4 py-2 text-sm font-semibold border border-gray-200 rounded-lg hover:border-red-400 hover:text-red-500 transition-colors">Client Portal</a>
        <a href="https://app.boxtocuba.ca/shipping-quote" class="px-4 py-2 text-sm font-semibold bg-red-500 text-white rounded-lg hover:bg-red-600 transition-colors">Get Quote →</a>
      </div>
    </div>
  </nav>

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100 px-6 py-3">
    <div class="max-w-5xl mx-auto text-sm text-gray-400">
      <a href="/" class="hover:text-red-500 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">Shipping Rates</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-white to-red-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-500 text-xs font-semibold px-4 py-2 rounded-full mb-5">📊 Updated rates 2026</div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Canada to Cuba<br class="hidden md:block" /> Shipping Rates
      </h1>
      <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-8">
        Clear rates by Cuban province — no hidden fees. Price per pound includes air freight and delivery in Cuba (door-to-door or pickup point depending on province). Pickup in Canada not included.
      </p>
      <div class="flex gap-3 flex-wrap">
        <a href="https://app.boxtocuba.ca/shipping-quote" class="px-6 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-colors">Calculate my shipment →</a>
        <a href="https://wa.me/14168365517" class="px-6 py-3 border border-gray-200 font-semibold rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">Ask on WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- HOW PRICING WORKS -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">How it's calculated</div>
      <h2 class="text-3xl font-extrabold mb-6">Actual weight vs. volumetric weight</h2>
      <p class="text-gray-600 mb-6">We charge based on whichever is greater: your package's <strong>actual weight</strong> or its <strong>volumetric weight</strong>. This is the standard for air cargo.</p>

      <div class="bg-blue-50 border-l-4 border-blue-400 rounded-xl p-6 mb-8">
        <div class="font-bold text-gray-800 mb-2">Volumetric weight formula</div>
        <div class="font-mono text-lg text-blue-700 mb-3">Length × Width × Height (cm) ÷ 139 = volumetric kg</div>
        <div class="text-sm text-gray-600">
          <strong>Example:</strong> A box of 50 × 40 × 30 cm → 50 × 40 × 30 ÷ 139 = <strong>43.2 volumetric kg</strong><br />
          If the actual weight is 20 kg, you're charged the volumetric weight (43.2 kg). Pack compactly to optimize cost.
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          ['📦', 'General items', 'Clothing, food, cosmetics, electronics, etc. Max 50 kg per box.'],
          ['💊', 'Medications', 'Cuban customs-exempt up to USD $200 per shipment, in original packaging.'],
          ['🍎', 'Packaged food', 'Exempt together with medications and hygiene up to USD $200. Factory sealed.'],
        ].map(([icon, title, desc]) => (
          <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
            <div class="text-2xl mb-3">{icon}</div>
            <h3 class="font-bold mb-2">{title}</h3>
            <p class="text-sm text-gray-500">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICE TABLE -->
  <section class="bg-gray-50 px-6 py-16" id="rates">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Rate table</div>
      <h2 class="text-3xl font-extrabold mb-3">Rates by Cuban Province</h2>
      <p class="text-gray-500 mb-8">Prices in Canadian dollars (CAD). Subject to change without notice.</p>

      <div class="overflow-x-auto rounded-2xl shadow-sm">
        <table class="w-full bg-white text-sm">
          <thead>
            <tr class="bg-gray-900 text-white">
              <th class="text-left px-5 py-4 font-semibold">Province</th>
              <th class="text-left px-5 py-4 font-semibold">Price per lb</th>
              <th class="text-left px-5 py-4 font-semibold">Estimated time</th>
              <th class="text-left px-5 py-4 font-semibold hidden md:table-cell">Notes</th>
            </tr>
          </thead>
          <tbody>
            {provinces.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                <td class="px-5 py-3 font-semibold text-gray-800">{p.name}</td>
                <td class="px-5 py-3 font-bold text-red-500">{p.price}</td>
                <td class="px-5 py-3 text-gray-600">{p.time}</td>
                <td class="px-5 py-3 text-gray-400 text-xs hidden md:table-cell">{p.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-3">* Delivery in Cuba included (door-to-door or pickup point depending on province). Pickup in Canada not included — available in the GTA for a fee, outside GTA via courier to our Toronto location.</p>
    </div>
  </section>

  <!-- ADDITIONAL CHARGES -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Additional charges</div>
      <h2 class="text-3xl font-extrabold mb-6">Are there additional fees?</h2>

      <div class="bg-green-50 border-l-4 border-green-400 rounded-xl p-6 mb-8">
        <div class="font-bold text-gray-800 mb-1">No hidden fees from our side</div>
        <p class="text-sm text-gray-600">The per-pound price includes: handling, air freight, and delivery in Cuba. Delivery method (door-to-door or pickup point) varies by province — our team will clarify at the time of booking.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          ['🚗 Pickup in Toronto (GTA)', 'Available within the Greater Toronto Area for a fee. Outside GTA: ship your package via courier to our Toronto location. Contact us to coordinate.'],
          ['🛡️ Optional insurance', 'Available for high-value declared packages.'],
          ['📦 Special packaging', 'For fragile items requiring extra protection.'],
          ['🏛️ Cuban customs duty', '30% on value exceeding USD $30. Recipient\'s responsibility in Cuba.'],
        ].map(([title, desc]) => (
          <div class="bg-white border border-gray-100 rounded-xl p-5">
            <div class="font-semibold text-gray-800 mb-1">{title}</div>
            <p class="text-sm text-gray-500">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 px-6 py-16" id="faq">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">FAQ</div>
      <h2 class="text-3xl font-extrabold mb-10">Frequently asked questions about pricing</h2>
      <div class="space-y-0">
        {faqItems.map((item) => (
          <details class="group border-b border-gray-200 py-5">
            <summary class="flex justify-between items-center font-semibold cursor-pointer list-none text-gray-800 hover:text-red-500 transition-colors">
              {item.q}
              <span class="text-red-500 text-xl ml-4 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-sm text-gray-500 leading-relaxed mt-3">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white text-center py-16 px-6">
    <h2 class="text-3xl font-extrabold mb-3">Get your exact quote</h2>
    <p class="opacity-80 mb-8 max-w-xl mx-auto">Enter the weight, dimensions and destination of your package to see the final price instantly — no registration needed.</p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="https://app.boxtocuba.ca/shipping-quote" class="inline-block px-8 py-4 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors text-lg">Calculate now →</a>
      <a href="https://wa.me/14168365517" class="inline-block px-8 py-4 bg-white/10 text-white font-bold rounded-xl hover:bg-white/20 transition-colors text-lg">WhatsApp</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-white px-6 py-12">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div>
        <img src="/logo.png" alt="Box to Cuba" class="w-12 h-12 object-contain mb-3 brightness-[10]" />
        <div class="font-bold text-lg mb-2">Box to Cuba</div>
        <p class="text-sm text-gray-400 leading-relaxed">Sending love from Canada to Cuba.</p>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">Quick links</h4>
        <div class="space-y-2">
          <a href="https://app.boxtocuba.ca/shipping-quote" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Get a Quote</a>
          <a href="https://app.boxtocuba.ca/client" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Client Portal</a>
          <a href="/#faq" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">FAQ</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">Resources</h4>
        <div class="space-y-2">
          <a href="/canada-to-cuba-shipping-rates" class="block text-sm text-red-400 font-semibold">Shipping Rates</a>
          <a href="/cuba-customs-guide" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Customs Guide</a>
          <a href="/cuba-prohibited-items" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Prohibited Items</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">Contact</h4>
        <div class="space-y-2">
          <a href="tel:+14168365517" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">+1 (416) 836-5517</a>
          <a href="mailto:info@boxtocuba.ca" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">info@boxtocuba.ca</a>
          <span class="block text-sm text-gray-400">Toronto, Ontario, Canada</span>
        </div>
      </div>
    </div>
    <div class="border-t border-gray-700 pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-gray-500">
      <span>© 2026 Box to Cuba. All rights reserved.</span>
      <span>Package shipping service Canada → Cuba</span>
    </div>
  </footer>

  <!-- WHATSAPP FLOAT -->
  <a href="https://wa.me/14168365517" target="_blank" rel="noopener noreferrer"
    class="fixed bottom-7 right-7 z-50 w-14 h-14 bg-green-500 rounded-full flex items-center justify-center text-2xl shadow-lg hover:scale-110 transition-transform"
    aria-label="WhatsApp">
    💬
  </a>

</BaseLayout>
