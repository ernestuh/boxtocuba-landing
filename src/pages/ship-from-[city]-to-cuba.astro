---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import { cities } from '../data/cities';
import { priceTiersByGroup, provinces } from '../data/provinces';
import { getNotice } from '../lib/cms';

export function getStaticPaths() {
  return cities.map((c) => ({
    params: { city: c.slug },
    props: { city: c },
  }));
}

const { city: c } = Astro.props;
const notice = await getNotice();
const showEasternDelay = notice.enabled && notice.capital_only.length > 0;
const waMsg = encodeURIComponent(`Hi! I'd like to ship a package from ${c.name} to Cuba. Can you give me more info?`);
const waUrl = `https://wa.me/14168365517?text=${waMsg}`;

const alternates = [
  { hreflang: 'en', href: `https://boxtocuba.ca/ship-from-${c.slug}-to-cuba/` },
  { hreflang: 'es', href: `https://boxtocuba.ca/es/enviar-desde-${c.slug}-a-cuba/` },
  { hreflang: 'fr', href: `https://boxtocuba.ca/fr/envoyer-de-${c.slug}-a-cuba/` },
  { hreflang: 'x-default', href: `https://boxtocuba.ca/ship-from-${c.slug}-to-cuba/` },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Canada to Cuba Shipping from ${c.name}`,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Box to Cuba',
    url: 'https://boxtocuba.ca',
    telephone: '+1-416-836-5517',
  },
  areaServed: [
    { '@type': 'City', name: c.name, containedInPlace: { '@type': 'Country', name: 'Canada' } },
    { '@type': 'Country', name: 'Cuba' },
  ],
  description: c.description_en,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'CAD',
    price: '6.00',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: '6.00',
      priceCurrency: 'CAD',
      unitCode: 'LB',
    },
  },
};

const westernTiers = priceTiersByGroup['western'];
const centralTiers = priceTiersByGroup['central-eastern'];
---

<BaseLayout
  lang="en"
  title={`Shipping from ${c.name} to Cuba | Box to Cuba`}
  description={`Send packages from ${c.name}, ${c.province_en} to Cuba. Weekly flights, door-to-door in Havana, pickup point in other provinces. From $6 CAD/lb. Get a free quote.`}
  faqItems={c.faq_en}
  alternates={alternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="head-extra" />

  <Navbar lang="en" langLinks={[
    { label: 'EN', href: `/ship-from-${c.slug}-to-cuba/` },
    { label: 'ES', href: `/es/enviar-desde-${c.slug}-a-cuba/` },
    { label: 'FR', href: `/fr/envoyer-de-${c.slug}-a-cuba/` },
  ]} />

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100 px-6 py-3">
    <div class="max-w-5xl mx-auto text-sm text-gray-400">
      <a href="/" class="hover:text-red-500 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">Shipping from {c.name} to Cuba</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-white to-red-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-500 text-xs font-semibold px-4 py-2 rounded-full mb-5">
        ✈️ Weekly flights · {c.name} → Cuba
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Shipping from {c.name} to Cuba
      </h1>
      <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-8">{c.description_en}</p>
      <div class="flex gap-3 flex-wrap">
        <a href="https://app.boxtocuba.ca/shipping-quote?lang=en" class="px-6 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-colors">Get a free quote →</a>
        <a href={waUrl} class="px-6 py-3 border border-gray-200 font-semibold rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">Ask on WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- QUICK STATS -->
  <section class="border-b border-gray-100 px-6 py-8">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center">
        <div class="text-2xl font-extrabold text-red-500">From $6/lb</div>
        <div class="text-xs text-gray-400 mt-1">Starting rate</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">7–14 days</div>
        <div class="text-xs text-gray-400 mt-1">To Havana area</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">Weekly</div>
        <div class="text-xs text-gray-400 mt-1">Flights to Cuba</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">16</div>
        <div class="text-xs text-gray-400 mt-1">Cuban provinces covered</div>
      </div>
    </div>
  </section>

  <!-- PICKUP INFO -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Pickup & Drop-off</div>
        <h2 class="text-3xl font-extrabold mb-4">How to send from {c.name}</h2>
        <p class="text-gray-500 leading-relaxed mb-6">{c.pickup_en}</p>
        <div class="space-y-3">
          {[
            ['📦', 'Pack your items and request a quote online'],
            ['🚗', 'Drop off at our office or schedule home pickup'],
            ['✈️', 'Weekly flight to Cuba — we handle customs'],
            ['🏠', 'Delivery to your family — door-to-door in Havana, pickup point in other provinces'],
          ].map(([icon, text]) => (
            <div class="flex items-center gap-3 text-sm text-gray-700">
              <span class="text-xl">{icon}</span>
              <span>{text}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
        <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-4">Contact us in {c.name}</div>
        <div class="space-y-4 text-sm">
          <div class="flex items-center gap-3">
            <span class="text-xl">📞</span>
            <a href="tel:+14168365517" class="font-semibold hover:text-red-500">+1 416-836-5517</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xl">💬</span>
            <a href={waUrl} class="font-semibold hover:text-red-500">WhatsApp</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xl">✉️</span>
            <a href="mailto:info@boxtocuba.ca" class="font-semibold hover:text-red-500">info@boxtocuba.ca</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RATES -->
  <section class="bg-gray-50 px-6 py-16" id="rates">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Rates</div>
      <h2 class="text-3xl font-extrabold mb-3">Shipping rates from {c.name} to Cuba</h2>
      <p class="text-gray-500 mb-8">All prices in Canadian dollars (CAD). The greater of actual or volumetric weight applies.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="bg-gray-900 text-white px-6 py-4 font-semibold text-sm">{westernTiers.label_en}</div>
          <ul class="divide-y divide-gray-50">
            {westernTiers.tiers.map((tier) => (
              <li class="px-6 py-4 flex items-center justify-between">
                <span class="text-gray-700 text-sm">{tier.split(':')[0]}</span>
                <span class="font-bold text-red-500">{tier.split(':')[1].trim()}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="bg-gray-900 text-white px-6 py-4 font-semibold text-sm">{centralTiers.label_en}</div>
          <ul class="divide-y divide-gray-50">
            {centralTiers.tiers.map((tier) => (
              <li class="px-6 py-4 flex items-center justify-between">
                <span class="text-gray-700 text-sm">{tier.split(':')[0]}</span>
                <span class="font-bold text-red-500">{tier.split(':')[1].trim()}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
      {showEasternDelay && (
        <div class="mt-6 bg-amber-50 border-l-4 border-amber-400 rounded-xl px-5 py-4 flex items-start gap-4">
          <div class="text-2xl leading-none mt-0.5">⚠️</div>
          <div class="flex-1">
            <div class="font-bold text-amber-800 text-sm mb-1">Temporary service change — Central &amp; Eastern Cuba</div>
            <p class="text-amber-700 text-sm leading-relaxed">
              There are currently no direct flights to some central and eastern provinces. All shipments travel via Havana and are transported overland.
              <strong>Delivery is temporarily limited to provincial capitals only.</strong> Delivery times may exceed estimates. Contact us for the latest updates.
            </p>
          </div>
          <a href={waUrl} class="flex-shrink-0 text-xs font-semibold text-amber-700 border border-amber-400 rounded-lg px-3 py-2 hover:bg-amber-100 transition-colors whitespace-nowrap">💬 Ask us</a>
        </div>
      )}
      <p class="text-xs text-gray-400 mt-4">* Delivery in Cuba included (door-to-door in Havana, pickup point in other provinces). Pickup in Canada not included in listed rates.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-6 py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">FAQ</div>
      <h2 class="text-3xl font-extrabold mb-10">Questions about shipping from {c.name} to Cuba</h2>
      <div class="space-y-4">
        {c.faq_en.map((item) => (
          <details class="bg-white rounded-2xl border border-gray-100 shadow-sm">
            <summary class="px-6 py-4 font-semibold text-gray-800 cursor-pointer hover:text-red-500 transition-colors list-none flex items-center justify-between">
              {item.q}
              <span class="text-red-400 text-lg">+</span>
            </summary>
            <div class="px-6 pb-4 text-gray-500 text-sm leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- PROVINCES -->
  <section class="px-6 py-16 border-t border-gray-100">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Delivery destinations</div>
      <h2 class="text-2xl font-extrabold mb-8">We deliver to all 16 Cuban provinces</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {provinces.map((p) => (
          <a href={`/provinces/${p.slug}/`}
            class="flex items-center justify-between px-4 py-3 bg-white rounded-xl border border-gray-100 shadow-sm hover:border-red-300 hover:shadow-md transition-all group">
            <div>
              <div class="font-semibold text-sm text-gray-800 group-hover:text-red-500 transition-colors">{p.name}</div>
              <div class="text-xs text-red-500 font-bold mt-0.5">{p.priceFrom}</div>
            </div>
            <span class="text-gray-300 group-hover:text-red-400 transition-colors">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white text-center py-20 px-6">
    <h2 class="text-3xl font-extrabold mb-3">Ready to send from {c.name}?</h2>
    <p class="opacity-80 mb-8">Get an instant quote — no registration required.</p>
    <a href="https://app.boxtocuba.ca/shipping-quote?lang=en" class="inline-block px-8 py-4 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors text-lg">Calculate my rate →</a>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 px-6 py-12">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="font-bold text-white text-lg mb-2">Box to Cuba</div>
        <p class="text-sm">Reliable parcel shipping from Canada to Cuba. Trusted by families since 2020.</p>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Quick Links</div>
        <ul class="space-y-2 text-sm">
          <li><a href="/canada-to-cuba-shipping-rates" class="hover:text-red-400 transition-colors">Shipping Rates</a></li>
          <li><a href="/cuba-customs-guide" class="hover:text-red-400 transition-colors">Customs Guide</a></li>
          <li><a href="/#faq" class="hover:text-red-400 transition-colors">FAQ</a></li>
          <li><a href="/#contact" class="hover:text-red-400 transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Contact</div>
        <ul class="space-y-2 text-sm">
          <li><a href="tel:+14168365517" class="hover:text-red-400 transition-colors">📞 +1 416-836-5517</a></li>
          <li><a href="mailto:info@boxtocuba.ca" class="hover:text-red-400 transition-colors">✉️ info@boxtocuba.ca</a></li>
          <li><a href="https://wa.me/14168365517" target="_blank" rel="noopener" class="hover:text-green-400 transition-colors">💬 WhatsApp</a></li>
          <li><a href="https://facebook.com/boxtocuba" target="_blank" rel="noopener" class="hover:text-blue-400 transition-colors">📘 Facebook</a></li>
          <li>📍 Toronto, Canada</li>
        </ul>
      </div>
    </div>
    <div class="max-w-5xl mx-auto mt-10 pt-6 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <span>© 2026 Box to Cuba. All rights reserved.</span>
      <a href="/privacy-policy/" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
    </div>
  </footer>
</BaseLayout>
