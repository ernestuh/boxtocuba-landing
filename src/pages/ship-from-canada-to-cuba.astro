---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import { cities } from '../data/cities';

const alternates = [
  { hreflang: 'en', href: 'https://boxtocuba.ca/ship-from-canada-to-cuba/' },
  { hreflang: 'es', href: 'https://boxtocuba.ca/es/enviar-desde-canada-a-cuba/' },
  { hreflang: 'fr', href: 'https://boxtocuba.ca/fr/envoyer-du-canada-a-cuba/' },
  { hreflang: 'x-default', href: 'https://boxtocuba.ca/ship-from-canada-to-cuba/' },
];

const provinceOrder = [
  'Ontario',
  'Quebec',
  'British Columbia',
  'Alberta',
  'Manitoba',
  'Nova Scotia',
];

const citiesByProvince = provinceOrder.map((province) => ({
  province,
  cities: cities.filter((c) => c.province_en === province),
})).filter((g) => g.cities.length > 0);
---

<BaseLayout
  lang="en"
  title="Shipping from Canada to Cuba | All Cities | Box to Cuba"
  description="Ship packages from any Canadian city to Cuba. Box to Cuba offers weekly flights, door-to-door delivery in Havana, pickup point in other provinces, and affordable rates from Toronto, Montreal, Vancouver, Calgary, and more."
  alternates={alternates}
>
  <Navbar lang="en" />

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100 px-6 py-3">
    <div class="max-w-5xl mx-auto text-sm text-gray-400">
      <a href="/" class="hover:text-red-500 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">Shipping from Canada to Cuba</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-white to-red-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-500 text-xs font-semibold px-4 py-2 rounded-full mb-5">
        ✈️ Weekly flights from Canada to Cuba
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Ship from Canada to Cuba
      </h1>
      <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-8">
        Box to Cuba ships packages from cities across Canada to Cuba every week. Same affordable rates — door-to-door delivery in Havana, pickup point in other provinces — no matter where you are in Canada.
      </p>
      <div class="flex gap-3 flex-wrap">
        <a href="https://app.boxtocuba.ca/shipping-quote?lang=en" class="px-6 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-colors">Get a free quote →</a>
        <a href="https://wa.me/14168365517" class="px-6 py-3 border border-gray-200 font-semibold rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">Ask on WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- QUICK STATS -->
  <section class="border-b border-gray-100 px-6 py-8">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center">
        <div class="text-2xl font-extrabold text-red-500">From $6/lb</div>
        <div class="text-xs text-gray-400 mt-1">Starting rate</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">Weekly</div>
        <div class="text-xs text-gray-400 mt-1">Flights to Cuba</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">{cities.length} cities</div>
        <div class="text-xs text-gray-400 mt-1">Across Canada</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">16</div>
        <div class="text-xs text-gray-400 mt-1">Cuban provinces covered</div>
      </div>
    </div>
  </section>

  <!-- CITIES BY PROVINCE -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Cities we serve</div>
      <h2 class="text-3xl font-extrabold mb-10">Select your city</h2>

      <div class="space-y-10">
        {citiesByProvince.map(({ province, cities: provinceCities }) => (
          <div>
            <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4">{province}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
              {provinceCities.map((c) => (
                <a
                  href={`/ship-from-${c.slug}-to-cuba/`}
                  class="flex items-center justify-between px-5 py-4 bg-white rounded-xl border border-gray-100 shadow-sm hover:border-red-300 hover:shadow-md transition-all group"
                >
                  <div>
                    <div class="font-semibold text-gray-800 group-hover:text-red-500 transition-colors">{c.name}</div>
                    <div class="text-xs text-gray-400 mt-0.5">{c.province_en}</div>
                  </div>
                  <span class="text-red-400 text-lg">→</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-gray-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">How it works</div>
      <h2 class="text-3xl font-extrabold mb-10">Shipping from Canada to Cuba in 4 steps</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          ['📦', 'Pack your items', 'Box up what you want to send and get a free quote online at app.boxtocuba.ca.'],
          ['🚚', 'Send to our Toronto hub', 'Drop off at our Scarborough office or ship your boxes via Canada Post, Purolator, or any courier.'],
          ['✈️', 'Weekly flight to Cuba', 'We consolidate and fly your shipment to Cuba every week — customs handled by us.'],
          ['🏠', 'Delivery in Cuba included', 'Door-to-door in Havana; pickup point in other provinces.'],
        ].map(([icon, title, desc]) => (
          <div class="bg-white rounded-2xl border border-gray-100 p-6 flex gap-4 items-start shadow-sm">
            <span class="text-3xl">{icon}</span>
            <div>
              <div class="font-bold text-gray-800 mb-1">{title}</div>
              <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white text-center py-20 px-6">
    <h2 class="text-3xl font-extrabold mb-3">Ready to send from Canada?</h2>
    <p class="opacity-80 mb-8">Get an instant quote — no registration required.</p>
    <a href="https://app.boxtocuba.ca/shipping-quote?lang=en" class="inline-block px-8 py-4 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors text-lg">Calculate my rate →</a>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 px-6 py-12">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="font-bold text-white text-lg mb-2">Box to Cuba</div>
        <p class="text-sm">Reliable parcel shipping from Canada to Cuba. Trusted by families since 2020.</p>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Quick Links</div>
        <ul class="space-y-2 text-sm">
          <li><a href="/canada-to-cuba-shipping-rates" class="hover:text-red-400 transition-colors">Shipping Rates</a></li>
          <li><a href="/cuba-customs-guide" class="hover:text-red-400 transition-colors">Customs Guide</a></li>
          <li><a href="/#faq" class="hover:text-red-400 transition-colors">FAQ</a></li>
          <li><a href="/#contact" class="hover:text-red-400 transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Contact</div>
        <ul class="space-y-2 text-sm">
          <li>📞 +1 416-836-5517</li>
          <li>✉️ info@boxtocuba.ca</li>
          <li>📍 Toronto & Montreal, Canada</li>
        </ul>
      </div>
    </div>
    <div class="max-w-5xl mx-auto mt-10 pt-6 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <span>© 2026 Box to Cuba. All rights reserved.</span>
      <span>Privacy Policy · Terms of Service</span>
    </div>
  </footer>
</BaseLayout>
