---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import { provinces, priceTiersByGroup } from '../../../data/provinces';
import { cities } from '../../../data/cities';
import { getNotice, getProvinceNoticeType } from '../../../lib/cms';

export function getStaticPaths() {
  return provinces.map((p) => ({
    params: { province: p.slug },
    props: { province: p },
  }));
}

const { province: p } = Astro.props;
const tiers = priceTiersByGroup[p.priceGroup];
const notice = await getNotice();
const noticeType = getProvinceNoticeType(notice, p.slug);
const capitalCity = p.capital ?? p.name_es;
const waMsg = encodeURIComponent(`Hola! Quiero enviar un paquete a ${p.name_es}. ¿Me pueden dar más información?`);
const waUrl = `https://wa.me/14168365517?text=${waMsg}`;

const alternates = [
  { hreflang: 'en', href: `https://boxtocuba.ca/provinces/${p.slug}/` },
  { hreflang: 'es', href: `https://boxtocuba.ca/es/provincias/${p.slug}/` },
  { hreflang: 'fr', href: `https://boxtocuba.ca/fr/provinces/${p.slug}/` },
  { hreflang: 'x-default', href: `https://boxtocuba.ca/provinces/${p.slug}/` },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Envío de paquetes de Canadá a ${p.name_es}`,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Box to Cuba',
    url: 'https://boxtocuba.ca',
    telephone: '+1-416-836-5517',
  },
  areaServed: {
    '@type': 'Place',
    name: `${p.name_es}, Cuba`,
  },
  description: p.description_es,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'CAD',
    price: p.priceGroup === 'western' ? '6.00' : p.priceGroup === 'matanzas' ? '6.50' : '6.85',
  },
};

const relatedProvinces = provinces.filter((pr) => p.relatedSlugs.includes(pr.slug));
---

<BaseLayout
  lang="es"
  title={`Envío a ${p.name_es}, Cuba desde Canadá | Box to Cuba`}
  description={`Envío de paquetes de Canadá a ${p.name_es}, Cuba — ${p.priceFrom_es}. Vuelos semanales, ${p.delivery_es}. Entrega a domicilio. Cotiza gratis.`}
  faqItems={p.faq_es}
  alternates={alternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="head-extra" />

  <Navbar lang="es" langLinks={[{label:"EN", href:`/provinces/${p.slug}/`}, {label:"FR", href:`/fr/provinces/${p.slug}/`}]} />

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100 px-6 py-3">
    <div class="max-w-5xl mx-auto text-sm text-gray-400">
      <a href="/es/" class="hover:text-red-500 transition-colors">Inicio</a>
      <span class="mx-2">›</span>
      <a href="/es/#destinations" class="hover:text-red-500 transition-colors">Todas las provincias</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">{p.name_es}</span>
    </div>
  </div>

  <!-- AVISO DE SERVICIO (controlado por CMS) -->
  {noticeType === 'capital_only' && (
    <div class="bg-amber-50 border-l-4 border-amber-400 px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-start gap-4">
        <div class="text-2xl leading-none mt-0.5">⚠️</div>
        <div class="flex-1">
          <div class="font-bold text-amber-800 text-sm mb-1">Cambio temporal de servicio — {p.name_es}</div>
          <p class="text-amber-700 text-sm leading-relaxed">
            Actualmente no hay vuelos directos a {p.name_es}. Todos los envíos viajan por La Habana y se transportan por tierra.
            <strong>La entrega está limitada temporalmente a {capitalCity} (capital provincial) únicamente.</strong> Los tiempos de entrega pueden superar los estimados. Contáctenos para más información.
          </p>
        </div>
        <a href={waUrl} class="flex-shrink-0 text-xs font-semibold text-amber-700 border border-amber-400 rounded-lg px-3 py-2 hover:bg-amber-100 transition-colors whitespace-nowrap">💬 Consúltenos</a>
      </div>
    </div>
  )}
  {noticeType === 'pickup_havana' && (
    <div class="bg-orange-50 border-l-4 border-orange-400 px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-start gap-4">
        <div class="text-2xl leading-none mt-0.5">📍</div>
        <div class="flex-1">
          <div class="font-bold text-orange-800 text-sm mb-1">Sin entrega a domicilio en {p.name_es} — Recogida en La Habana</div>
          <p class="text-orange-700 text-sm leading-relaxed">
            Actualmente no realizamos entregas en {p.name_es}. Su paquete quedará retenido en nuestra <strong>oficina de La Habana</strong> para ser recogido.
            El destinatario debe desplazarse a La Habana para recogerlo. Contáctenos para coordinar la recogida.
          </p>
        </div>
        <a href={waUrl} class="flex-shrink-0 text-xs font-semibold text-orange-700 border border-orange-400 rounded-lg px-3 py-2 hover:bg-orange-100 transition-colors whitespace-nowrap">💬 Consúltenos</a>
      </div>
    </div>
  )}
  {noticeType === 'pickup_santiago' && (
    <div class="bg-red-50 border-l-4 border-red-400 px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-start gap-4">
        <div class="text-2xl leading-none mt-0.5">🚫</div>
        <div class="flex-1">
          <div class="font-bold text-red-800 text-sm mb-1">Sin servicio de entrega a {p.name_es}</div>
          <p class="text-red-700 text-sm leading-relaxed">
            Actualmente no entregamos en la provincia de {p.name_es}. Su paquete puede enviarse a <strong>Santiago de Cuba</strong> y recogerse en nuestra oficina de Santiago de Cuba. Contáctenos para coordinar el envío y la recogida.
          </p>
        </div>
        <a href={waUrl} class="flex-shrink-0 text-xs font-semibold text-red-700 border border-red-400 rounded-lg px-3 py-2 hover:bg-red-100 transition-colors whitespace-nowrap">💬 Consúltenos</a>
      </div>
    </div>
  )}

  <!-- HERO -->
  <section class="bg-gradient-to-br from-white to-red-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-500 text-xs font-semibold px-4 py-2 rounded-full mb-5">
        ✈️ Vuelos semanales · Canadá → Cuba
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Envío a {p.name_es}, Cuba
      </h1>
      <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-8">{p.description_es}</p>
      <div class="flex gap-3 flex-wrap">
        <a href="https://app.boxtocuba.ca/shipping-quote?lang=es" class="px-6 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-colors">Cotizar gratis →</a>
        <a href={waUrl} class="px-6 py-3 border border-gray-200 font-semibold rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">Preguntar por WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- QUICK STATS -->
  <section class="border-b border-gray-100 px-6 py-8">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center">
        <div class="text-2xl font-extrabold text-red-500">{p.priceFrom_es}</div>
        <div class="text-xs text-gray-400 mt-1">Tarifa inicial</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">{p.delivery_es}</div>
        <div class="text-xs text-gray-400 mt-1">Entrega estimada</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">Semanal</div>
        <div class="text-xs text-gray-400 mt-1">Vuelos a Cuba</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">{p.municipalities.length}</div>
        <div class="text-xs text-gray-400 mt-1">Municipios cubiertos</div>
      </div>
    </div>
  </section>

  <!-- RATE TABLE -->
  <section class="px-6 py-16" id="tarifas">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Tarifas</div>
      <h2 class="text-3xl font-extrabold mb-3">Tarifas de envío a {p.name_es}</h2>
      <p class="text-gray-500 mb-8">Todos los precios en dólares canadienses (CAD). La tarifa se aplica según el mayor entre el peso real y el volumétrico.</p>

      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-6">
        <div class="bg-gray-900 text-white px-6 py-4 font-semibold text-sm">{tiers.label_es}</div>
        <ul class="divide-y divide-gray-50">
          {tiers.tiers.map((tier) => (
            <li class="px-6 py-4 flex items-center justify-between">
              <span class="text-gray-700 text-sm">{tier.split(':')[0]}</span>
              <span class="font-bold text-red-500">{tier.split(':')[1].trim()}</span>
            </li>
          ))}
        </ul>
      </div>

      {p.note_es && (
        <div class="bg-blue-50 border-l-4 border-blue-400 rounded-xl p-4 text-sm text-gray-700">
          <strong>Nota:</strong> {p.note_es}
        </div>
      )}

      <p class="text-xs text-gray-400 mt-4">* Entrega en Cuba incluida (puerta a puerta o punto de recogida). Recogida en Canadá no incluida.</p>
    </div>
  </section>

  <!-- MUNICIPALITIES -->
  <section class="bg-gray-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Cobertura</div>
      <h2 class="text-3xl font-extrabold mb-3">Entregamos en toda {p.name_es}</h2>
      <p class="text-gray-500 mb-8">Cubrimos todos los municipios de la provincia de {p.name_es} — desde las ciudades principales hasta las comunidades más pequeñas.</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {p.municipalities.map((m) => (
          <div class="bg-white border border-gray-100 rounded-xl p-3 text-center text-sm font-medium text-gray-700 hover:border-red-300 hover:text-red-500 transition-all">
            📍 {m}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Proceso</div>
      <h2 class="text-3xl font-extrabold mb-10">Envía a {p.name_es} en 3 pasos</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          ['1', 'Cotiza tu envío', 'Ingresa los detalles de tu paquete y tu destino en ' + p.name_es + '. Obtén un precio al instante — sin registro.'],
          ['2', 'Entrega o recogida a domicilio', 'Trae tu paquete a nuestra ubicación en Toronto o Montreal, o programa una recogida en tu puerta.'],
          ['3', 'Entregado en ' + p.name_es, 'Tu paquete llega a tu familia en ' + p.name_es + ' en ' + p.delivery_es + '. Rastréalo en todo momento desde el portal.'],
        ].map(([num, title, desc]) => (
          <div class="flex flex-col items-start">
            <div class="w-10 h-10 rounded-full bg-red-500 text-white font-extrabold flex items-center justify-center mb-4">{num}</div>
            <h3 class="font-bold text-lg mb-2">{title}</h3>
            <p class="text-gray-500 text-sm">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 px-6 py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">FAQ</div>
      <h2 class="text-3xl font-extrabold mb-10">Preguntas frecuentes sobre envíos a {p.name_es}</h2>
      <div class="space-y-4">
        {p.faq_es.map((item) => (
          <details class="bg-white rounded-2xl border border-gray-100 shadow-sm">
            <summary class="px-6 py-4 font-semibold text-gray-800 cursor-pointer hover:text-red-500 transition-colors list-none flex items-center justify-between">
              {item.q}
              <span class="text-red-400 text-lg">+</span>
            </summary>
            <div class="px-6 pb-4 text-gray-500 text-sm leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED PROVINCES -->
  {relatedProvinces.length > 0 && (
    <section class="px-6 py-16">
      <div class="max-w-5xl mx-auto">
        <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Explorar</div>
        <h2 class="text-3xl font-extrabold mb-8">Otras provincias que cubrimos</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedProvinces.map((rp) => (
            <a href={`/es/provincias/${rp.slug}/`} class="bg-white border border-gray-100 rounded-2xl p-5 hover:border-red-300 hover:shadow-md transition-all group">
              <div class="text-2xl mb-2">📦</div>
              <h3 class="font-bold text-gray-800 group-hover:text-red-500 mb-1">{rp.name_es}</h3>
              <div class="text-xs text-red-500 font-bold">{rp.priceFrom_es}</div>
              <div class="text-xs text-gray-400 mt-1">{rp.delivery_es}</div>
            </a>
          ))}
        </div>
        <div class="mt-8">
          <a href="/es/#destinations" class="text-sm text-red-500 font-semibold hover:underline">← Ver las 16 provincias cubanas</a>
        </div>
      </div>
    </section>
  )}

  <!-- CANADIAN CITIES -->
  <section class="px-6 py-16 border-t border-gray-100">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Enviar desde Canadá</div>
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
        <h2 class="text-2xl font-extrabold">Envía a {p.name_es} desde cualquier ciudad de Canadá</h2>
        <a href="/es/enviar-desde-canada-a-cuba/" class="text-sm font-semibold text-red-500 hover:underline whitespace-nowrap">Ver todas las ciudades →</a>
      </div>
      <div class="flex flex-wrap gap-3">
        {cities.map((c) => (
          <a href={`/es/enviar-desde-${c.slug}-a-cuba/`}
            class="px-4 py-2 bg-white rounded-xl border border-gray-100 shadow-sm text-sm font-medium text-gray-700 hover:border-red-300 hover:text-red-500 transition-all">{c.name}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white text-center py-20 px-6">
    <h2 class="text-3xl font-extrabold mb-3">¿Listo para enviar un paquete a {p.name_es}?</h2>
    <p class="opacity-80 mb-8">Obtén una cotización al instante — sin registro.</p>
    <a href="https://app.boxtocuba.ca/shipping-quote?lang=es" class="inline-block px-8 py-4 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors text-lg">Calcular mi tarifa →</a>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 px-6 py-12">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="font-bold text-white text-lg mb-2">Box to Cuba</div>
        <p class="text-sm">Envío confiable de paquetes de Canadá a Cuba. Con la confianza de familias desde 2020.</p>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Enlaces rápidos</div>
        <ul class="space-y-2 text-sm">
          <li><a href="/es/precios-envio-canada-cuba" class="hover:text-red-400 transition-colors">Tarifas de envío</a></li>
          <li><a href="/es/guia-aduana-cuba" class="hover:text-red-400 transition-colors">Guía de Aduana</a></li>
          <li><a href="/es/#faq" class="hover:text-red-400 transition-colors">FAQ</a></li>
          <li><a href="/es/#contact" class="hover:text-red-400 transition-colors">Contacto</a></li>
        </ul>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Contacto</div>
        <ul class="space-y-2 text-sm">
          <li><a href="tel:+14168365517" class="hover:text-red-400 transition-colors">📞 +1 416-836-5517</a></li>
          <li><a href="mailto:info@boxtocuba.ca" class="hover:text-red-400 transition-colors">✉️ info@boxtocuba.ca</a></li>
          <li><a href="https://wa.me/14168365517" target="_blank" rel="noopener" class="hover:text-green-400 transition-colors">💬 WhatsApp</a></li>
          <li>📍 Toronto y Montreal, Canadá</li>
        </ul>
      </div>
    </div>
    <div class="max-w-5xl mx-auto mt-10 pt-6 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <span>© 2026 Box to Cuba. Todos los derechos reservados.</span>
      <a href="/es/politica-de-privacidad/" class="hover:text-gray-300 transition-colors">Política de Privacidad</a>
    </div>
  </footer>
</BaseLayout>
