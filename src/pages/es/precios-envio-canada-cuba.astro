---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { provinces as provinceData } from '../../data/provinces';
import { getNotice, getProvinceNoticeType } from '../../lib/cms';

const faqItems = [
  { q: '¿El precio es en dólares canadienses o americanos?', a: 'Todos nuestros precios están en dólares canadienses (CAD). Aceptamos pago en efectivo y transferencia Interac (e-Transfer).' },
  { q: '¿Puedo enviar varias cajas con diferentes destinos en Cuba?', a: 'Sí. Cada caja puede tener un destinatario diferente. Cada caja se cotiza según su peso y provincia de destino.' },
  { q: '¿Hay descuento por volumen?', a: 'Sí, ofrecemos tarifas especiales para clientes frecuentes y envíos de alto volumen. Contáctanos para discutir un plan personalizado.' },
  { q: '¿El precio incluye la entrega en Cuba?', a: 'Sí, la entrega en Cuba está incluida en la tarifa. La modalidad (puerta a puerta o punto de recogida) depende de la provincia — nuestro equipo te lo confirmará al coordinar el envío.' },
  { q: '¿Cuándo debo pagar?', a: 'El pago se realiza al momento de entregar o programar la recogida de tu paquete. No se requiere pago anticipado online.' },
];

const notice = await getNotice();
const provinces = provinceData.map((p) => ({
  slug: p.slug,
  name: p.name_es,
  price: p.priceFrom_es,
  time: p.delivery_es,
  note: p.note_es ?? '—',
  noticeType: getProvinceNoticeType(notice, p.slug),
}));
const hasCapitalOnly  = notice.enabled && notice.capital_only.length > 0;
const hasPickupHavana = notice.enabled && notice.pickup_havana.length > 0;
const hasPickupSantiago = notice.enabled && notice.pickup_santiago.length > 0;
---

<BaseLayout
  lang="es"
  title="Precios de Envío a Cuba desde Canadá | Box to Cuba"
  description="Tarifas de envío a todas las provincias de Cuba. Sin cargos ocultos. Desde $75 CAD. Obtén tu cotización en segundos."
  faqItems={faqItems}
>

  <Navbar lang="es" />

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100 px-6 py-3">
    <div class="max-w-5xl mx-auto text-sm text-gray-400">
      <a href="/es/" class="hover:text-red-500 transition-colors">Inicio</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">Precios de Envío</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-white to-red-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-500 text-xs font-semibold px-4 py-2 rounded-full mb-5">📊 Tarifas actualizadas 2026</div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Precios de Envío a Cuba<br class="hidden md:block" /> desde Canadá
      </h1>
      <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-8">
        Tarifas claras por provincia cubana, sin cargos ocultos. El precio por libra incluye flete aéreo y entrega en Cuba (puerta a puerta o en punto de recogida según la provincia). La recogida en Canadá no está incluida.
      </p>
      <div class="flex gap-3 flex-wrap">
        <a href="https://app.boxtocuba.ca/shipping-quote" class="px-6 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-colors">Calcular mi envío →</a>
        <a href="https://wa.me/14168365517" class="px-6 py-3 border border-gray-200 font-semibold rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">Consultar por WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- HOW PRICING WORKS -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">¿Cómo se calcula?</div>
      <h2 class="text-3xl font-extrabold mb-6">Precio real vs. peso volumétrico</h2>
      <p class="text-gray-600 mb-6">Se cobra el mayor entre el <strong>peso real</strong> de tu paquete y el <strong>peso volumétrico</strong>. Esto es el estándar de la industria de carga aérea.</p>

      <div class="bg-blue-50 border-l-4 border-blue-400 rounded-xl p-6 mb-8">
        <div class="font-bold text-gray-800 mb-2">Fórmula de peso volumétrico</div>
        <div class="font-mono text-lg text-blue-700 mb-3">Largo × Ancho × Alto (cm) ÷ 139 = kg volumétricos</div>
        <div class="text-sm text-gray-600">
          <strong>Ejemplo:</strong> Una caja de 50 × 40 × 30 cm → 50 × 40 × 30 ÷ 139 = <strong>43.2 kg volumétricos</strong><br />
          Si el peso real es 20 kg, se cobra el volumétrico (43.2 kg). Empaca compacto para optimizar el costo.
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
          <div class="text-2xl mb-3">📦</div>
          <h3 class="font-bold mb-2">Artículos generales</h3>
          <p class="text-sm text-gray-500">Ropa, alimentos, cosméticos, electrónicos, etc. Peso máximo 50 kg por caja.</p>
        </div>
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
          <div class="text-2xl mb-3">💊</div>
          <h3 class="font-bold mb-2">Medicamentos</h3>
          <p class="text-sm text-gray-500">Exentos de arancel cubano hasta USD $200 por envío, en empaque original.</p>
        </div>
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
          <div class="text-2xl mb-3">🍎</div>
          <h3 class="font-bold mb-2">Alimentos empacados</h3>
          <p class="text-sm text-gray-500">Exentos junto con medicamentos y aseo hasta USD $200. Sellados de fábrica.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICE TABLE -->
  <section class="bg-gray-50 px-6 py-16" id="tarifas">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Tabla de tarifas</div>
      <h2 class="text-3xl font-extrabold mb-3">Tarifas por provincia de Cuba</h2>
      <p class="text-gray-500 mb-8">Precios en dólares canadienses (CAD). Sujetos a cambios sin previo aviso.</p>

      <div class="overflow-x-auto rounded-2xl shadow-sm">
        <table class="w-full bg-white text-sm">
          <thead>
            <tr class="bg-gray-900 text-white">
              <th class="text-left px-5 py-4 font-semibold">Provincia</th>
              <th class="text-left px-5 py-4 font-semibold">Precio por libra</th>
              <th class="text-left px-5 py-4 font-semibold">Tiempo estimado</th>
              <th class="text-left px-5 py-4 font-semibold hidden md:table-cell">Notas</th>
            </tr>
          </thead>
          <tbody>
            {provinces.map((p, i) => (
              <tr class={`${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}${p.noticeType === 'capital_only' ? ' border-l-2 border-amber-400' : p.noticeType === 'pickup_havana' ? ' border-l-2 border-orange-400' : p.noticeType === 'pickup_santiago' ? ' border-l-2 border-red-400' : ''}`}>
                <td class="px-5 py-3 font-semibold text-gray-800">
                  <a href={`/es/provincias/${p.slug}/`} class="hover:text-red-500 transition-colors">{p.name}</a>
                </td>
                <td class="px-5 py-3 font-bold text-red-500">{p.price}</td>
                <td class="px-5 py-3 text-gray-600">{p.time}</td>
                <td class="px-5 py-3 text-xs hidden md:table-cell">
                  {p.noticeType === 'capital_only' && <span class="inline-flex items-center gap-1 text-amber-700 font-semibold bg-amber-50 border border-amber-200 rounded-full px-2 py-0.5">⚠️ Solo capital</span>}
                  {p.noticeType === 'pickup_havana' && <span class="inline-flex items-center gap-1 text-orange-600 font-semibold bg-orange-50 border border-orange-200 rounded-full px-2 py-0.5">📍 Recogida en La Habana</span>}
                  {p.noticeType === 'pickup_santiago' && <span class="inline-flex items-center gap-1 text-red-600 font-semibold bg-red-50 border border-red-200 rounded-full px-2 py-0.5">🚫 Recogida en Santiago</span>}
                  {!p.noticeType && <span class="text-gray-400">{p.note}</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {hasCapitalOnly && (
        <div class="flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl p-4 mt-4">
          <span class="text-base leading-none mt-0.5">⚠️</span>
          <p class="text-amber-800 text-sm"><strong>Solo capital provincial (temporal):</strong> Las provincias marcadas ⚠️ se sirven únicamente en su capital provincial — sin vuelos directos disponibles. Toda la carga viaja por La Habana y se transporta por tierra. Los tiempos de entrega pueden superar los estimados. <a href="https://wa.me/14168365517" class="underline font-semibold">Contáctenos</a> para más información.</p>
        </div>
      )}
      {hasPickupHavana && (
        <div class="flex items-start gap-3 bg-orange-50 border border-orange-200 rounded-xl p-4 mt-3">
          <span class="text-base leading-none mt-0.5">📍</span>
          <p class="text-orange-800 text-sm"><strong>Recogida en La Habana:</strong> Artemisa, Mayabeque, Pinar del Río e Isla de la Juventud actualmente no tienen entrega a domicilio. Los paquetes deben recogerse en nuestra oficina de La Habana. <a href="https://wa.me/14168365517" class="underline font-semibold">Contáctenos</a> para coordinar.</p>
        </div>
      )}
      {hasPickupSantiago && (
        <div class="flex items-start gap-3 bg-red-50 border border-red-200 rounded-xl p-4 mt-3">
          <span class="text-base leading-none mt-0.5">🚫</span>
          <p class="text-red-800 text-sm"><strong>Sin entrega a Guantánamo:</strong> Actualmente no entregamos en la provincia de Guantánamo. Los paquetes pueden recogerse en nuestra ubicación de Santiago de Cuba. <a href="https://wa.me/14168365517" class="underline font-semibold">Contáctenos</a> para coordinar.</p>
        </div>
      )}

      <p class="text-xs text-gray-400 mt-3">* Entrega incluida (puerta a puerta o punto de recogida según la provincia). Recogida en Canadá no incluida — disponible en el GTA por una tarifa, fuera del GTA vía courier a nuestra ubicación en Toronto.</p>
    </div>
  </section>

  <!-- ADDITIONAL CHARGES -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Cargos adicionales</div>
      <h2 class="text-3xl font-extrabold mb-6">¿Hay cargos adicionales?</h2>

      <div class="bg-green-50 border-l-4 border-green-400 rounded-xl p-6 mb-8">
        <div class="font-bold text-gray-800 mb-1">Sin cargos ocultos de nuestra parte</div>
        <p class="text-sm text-gray-600">El precio por libra incluye: manejo, flete aéreo y entrega en Cuba. La modalidad de entrega (puerta a puerta o punto de recogida) varía según la provincia — nuestro equipo te lo confirmará al coordinar el envío.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          ['🚗 Recogida en Toronto (GTA)', 'Disponible dentro del Greater Toronto Area por una tarifa adicional. Fuera del GTA: envía tu paquete via courier a nuestra ubicación en Toronto. Contáctanos para coordinar.'],
          ['🛡️ Seguro opcional', 'Disponible para paquetes de alto valor declarado.'],
          ['📦 Embalaje especial', 'Para artículos frágiles que requieren protección adicional.'],
          ['🏛️ Arancel cubano', '30% sobre el valor que exceda USD $30. Responsabilidad del destinatario en Cuba.'],
        ].map(([title, desc]) => (
          <div class="bg-white border border-gray-100 rounded-xl p-5">
            <div class="font-semibold text-gray-800 mb-1">{title}</div>
            <p class="text-sm text-gray-500">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 px-6 py-16" id="faq">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Preguntas frecuentes</div>
      <h2 class="text-3xl font-extrabold mb-10">Preguntas sobre precios</h2>
      <div class="space-y-0">
        {faqItems.map((item) => (
          <details class="group border-b border-gray-200 py-5">
            <summary class="flex justify-between items-center font-semibold cursor-pointer list-none text-gray-800 hover:text-red-500 transition-colors">
              {item.q}
              <span class="text-red-500 text-xl ml-4 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-sm text-gray-500 leading-relaxed mt-3">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white text-center py-16 px-6">
    <h2 class="text-3xl font-extrabold mb-3">Obtén tu cotización exacta</h2>
    <p class="opacity-80 mb-8 max-w-xl mx-auto">Ingresa el peso, dimensiones y destino de tu paquete para ver el precio final al instante — sin registro.</p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="https://app.boxtocuba.ca/shipping-quote" class="inline-block px-8 py-4 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors text-lg">Calcular ahora →</a>
      <a href="https://wa.me/14168365517" class="inline-block px-8 py-4 bg-white/10 text-white font-bold rounded-xl hover:bg-white/20 transition-colors text-lg">WhatsApp</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-white px-6 py-12">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div>
        <img src="/logo.png" alt="Box to Cuba" class="w-12 h-12 object-contain mb-3 brightness-[10]" />
        <div class="font-bold text-lg mb-2">Box to Cuba</div>
        <p class="text-sm text-gray-400 leading-relaxed">Enviando amor de Canadá a Cuba desde hace años.</p>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">Links rápidos</h4>
        <div class="space-y-2">
          <a href="https://app.boxtocuba.ca/shipping-quote" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Cotizar envío</a>
          <a href="https://app.boxtocuba.ca/client" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Portal Cliente</a>
          <a href="/es/#faq" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">FAQ</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">Recursos</h4>
        <div class="space-y-2">
          <a href="/es/precios-envio-canada-cuba" class="block text-sm text-red-400 font-semibold">Tarifas de Envío</a>
          <a href="/es/guia-aduana-cuba" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Guía de Aduana</a>
          <a href="/es/articulos-prohibidos-cuba" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Artículos Prohibidos</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">Contacto</h4>
        <div class="space-y-2">
          <a href="tel:+14168365517" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">+1 (416) 836-5517</a>
          <a href="mailto:info@boxtocuba.ca" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">info@boxtocuba.ca</a>
          <span class="block text-sm text-gray-400">Toronto, Ontario, Canada</span>
        </div>
      </div>
    </div>
    <div class="border-t border-gray-700 pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-gray-500">
      <span>© 2026 Box to Cuba. Todos los derechos reservados.</span>
      <span>Servicio de paquetería Canada → Cuba</span>
    </div>
  </footer>

</BaseLayout>
