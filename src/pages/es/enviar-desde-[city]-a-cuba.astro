---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { cities } from '../../data/cities';
import { priceTiersByGroup, provinces } from '../../data/provinces';
import { getNotice } from '../../lib/cms';

export function getStaticPaths() {
  return cities.map((c) => ({
    params: { city: c.slug },
    props: { city: c },
  }));
}

const { city: c } = Astro.props;
const notice = await getNotice();
const showEasternDelay = notice.enabled && notice.capital_only.length > 0;
const waMsg = encodeURIComponent(`Hola! Quiero enviar un paquete desde ${c.name} a Cuba. ¿Me pueden dar más información?`);
const waUrl = `https://wa.me/14168365517?text=${waMsg}`;

const alternates = [
  { hreflang: 'en', href: `https://boxtocuba.ca/ship-from-${c.slug}-to-cuba/` },
  { hreflang: 'es', href: `https://boxtocuba.ca/es/enviar-desde-${c.slug}-a-cuba/` },
  { hreflang: 'fr', href: `https://boxtocuba.ca/fr/envoyer-de-${c.slug}-a-cuba/` },
  { hreflang: 'x-default', href: `https://boxtocuba.ca/ship-from-${c.slug}-to-cuba/` },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Envío de Canadá a Cuba desde ${c.name}`,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Box to Cuba',
    url: 'https://boxtocuba.ca',
    telephone: '+1-416-836-5517',
  },
  areaServed: [
    { '@type': 'City', name: c.name, containedInPlace: { '@type': 'Country', name: 'Canada' } },
    { '@type': 'Country', name: 'Cuba' },
  ],
  description: c.description_es,
};

const westernTiers = priceTiersByGroup['western'];
const centralTiers = priceTiersByGroup['central-eastern'];
---

<BaseLayout
  lang="es"
  title={`Enviar paquetes desde ${c.name} a Cuba | Box to Cuba`}
  description={`Envía paquetes desde ${c.name}, ${c.province_es} a Cuba. Vuelos semanales, entrega puerta a puerta en La Habana, punto de recogida en otras provincias. Desde $6 CAD/lb. Solicita una cotización gratis.`}
  faqItems={c.faq_es}
  alternates={alternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="head-extra" />

  <Navbar lang="es" langLinks={[
    { label: 'EN', href: `/ship-from-${c.slug}-to-cuba/` },
    { label: 'ES', href: `/es/enviar-desde-${c.slug}-a-cuba/` },
    { label: 'FR', href: `/fr/envoyer-de-${c.slug}-a-cuba/` },
  ]} />

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100 px-6 py-3">
    <div class="max-w-5xl mx-auto text-sm text-gray-400">
      <a href="/es/" class="hover:text-red-500 transition-colors">Inicio</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">Enviar desde {c.name} a Cuba</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-white to-red-50 px-6 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-500 text-xs font-semibold px-4 py-2 rounded-full mb-5">
        ✈️ Vuelos semanales · {c.name} → Cuba
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Envío desde {c.name} a Cuba
      </h1>
      <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-8">{c.description_es}</p>
      <div class="flex gap-3 flex-wrap">
        <a href="https://app.boxtocuba.ca/shipping-quote?lang=es" class="px-6 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-colors">Cotizar ahora →</a>
        <a href={waUrl} class="px-6 py-3 border border-gray-200 font-semibold rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- QUICK STATS -->
  <section class="border-b border-gray-100 px-6 py-8">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center">
        <div class="text-2xl font-extrabold text-red-500">Desde $6/lb</div>
        <div class="text-xs text-gray-400 mt-1">Tarifa inicial</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">7–14 días</div>
        <div class="text-xs text-gray-400 mt-1">A La Habana</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">Semanal</div>
        <div class="text-xs text-gray-400 mt-1">Vuelos a Cuba</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-gray-800">16</div>
        <div class="text-xs text-gray-400 mt-1">Provincias cubanas</div>
      </div>
    </div>
  </section>

  <!-- PICKUP INFO -->
  <section class="px-6 py-16">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Recogida y entrega</div>
        <h2 class="text-3xl font-extrabold mb-4">Cómo enviar desde {c.name}</h2>
        <p class="text-gray-500 leading-relaxed mb-6">{c.pickup_es}</p>
        <div class="space-y-3">
          {[
            ['📦', 'Empaca tus artículos y solicita una cotización en línea'],
            ['🚗', 'Entrega en nuestra oficina o programa recogida a domicilio'],
            ['✈️', 'Vuelo semanal a Cuba — nosotros manejamos la aduana'],
            ['🏠', 'Entrega a tu familia — puerta a puerta en La Habana, punto de recogida en otras provincias'],
          ].map(([icon, text]) => (
            <div class="flex items-center gap-3 text-sm text-gray-700">
              <span class="text-xl">{icon}</span>
              <span>{text}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
        <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-4">Contáctanos en {c.name}</div>
        <div class="space-y-4 text-sm">
          <div class="flex items-center gap-3">
            <span class="text-xl">📞</span>
            <a href="tel:+14168365517" class="font-semibold hover:text-red-500">+1 416-836-5517</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xl">💬</span>
            <a href={waUrl} class="font-semibold hover:text-red-500">WhatsApp</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xl">✉️</span>
            <a href="mailto:info@boxtocuba.ca" class="font-semibold hover:text-red-500">info@boxtocuba.ca</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RATES -->
  <section class="bg-gray-50 px-6 py-16" id="tarifas">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Tarifas</div>
      <h2 class="text-3xl font-extrabold mb-3">Tarifas de envío desde {c.name} a Cuba</h2>
      <p class="text-gray-500 mb-8">Todos los precios en dólares canadienses (CAD). Se aplica el mayor entre el peso real y el volumétrico.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="bg-gray-900 text-white px-6 py-4 font-semibold text-sm">{westernTiers.label_es}</div>
          <ul class="divide-y divide-gray-50">
            {westernTiers.tiers.map((tier) => (
              <li class="px-6 py-4 flex items-center justify-between">
                <span class="text-gray-700 text-sm">{tier.split(':')[0]}</span>
                <span class="font-bold text-red-500">{tier.split(':')[1].trim()}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="bg-gray-900 text-white px-6 py-4 font-semibold text-sm">{centralTiers.label_es}</div>
          <ul class="divide-y divide-gray-50">
            {centralTiers.tiers.map((tier) => (
              <li class="px-6 py-4 flex items-center justify-between">
                <span class="text-gray-700 text-sm">{tier.split(':')[0]}</span>
                <span class="font-bold text-red-500">{tier.split(':')[1].trim()}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
      {showEasternDelay && (
        <div class="mt-6 bg-amber-50 border-l-4 border-amber-400 rounded-xl px-5 py-4 flex items-start gap-4">
          <div class="text-2xl leading-none mt-0.5">⚠️</div>
          <div class="flex-1">
            <div class="font-bold text-amber-800 text-sm mb-1">Cambio temporal de servicio — Cuba central y oriental</div>
            <p class="text-amber-700 text-sm leading-relaxed">
              Actualmente no hay vuelos directos a algunas provincias del centro y oriente del país. Todos los envíos viajan vía La Habana y se transportan por tierra.
              <strong>La entrega está temporalmente limitada a las capitales provinciales únicamente.</strong> Los tiempos de entrega pueden superar los estimados. Contáctenos para obtener la información más reciente.
            </p>
          </div>
          <a href={waUrl} class="flex-shrink-0 text-xs font-semibold text-amber-700 border border-amber-400 rounded-lg px-3 py-2 hover:bg-amber-100 transition-colors whitespace-nowrap">💬 Pregúntanos</a>
        </div>
      )}
      <p class="text-xs text-gray-400 mt-4">* Entrega en Cuba incluida (puerta a puerta en La Habana, punto de recogida en otras provincias). La recogida en Canadá no está incluida en las tarifas indicadas.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-6 py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">FAQ</div>
      <h2 class="text-3xl font-extrabold mb-10">Preguntas frecuentes sobre envíos desde {c.name} a Cuba</h2>
      <div class="space-y-4">
        {c.faq_es.map((item) => (
          <details class="bg-white rounded-2xl border border-gray-100 shadow-sm">
            <summary class="px-6 py-4 font-semibold text-gray-800 cursor-pointer hover:text-red-500 transition-colors list-none flex items-center justify-between">
              {item.q}
              <span class="text-red-400 text-lg">+</span>
            </summary>
            <div class="px-6 pb-4 text-gray-500 text-sm leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- PROVINCES -->
  <section class="px-6 py-16 border-t border-gray-100">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">Destinos de entrega</div>
      <h2 class="text-2xl font-extrabold mb-8">Entregamos en las 16 provincias de Cuba</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {provinces.map((p) => (
          <a href={`/es/provincias/${p.slug}/`}
            class="flex items-center justify-between px-4 py-3 bg-white rounded-xl border border-gray-100 shadow-sm hover:border-red-300 hover:shadow-md transition-all group">
            <div>
              <div class="font-semibold text-sm text-gray-800 group-hover:text-red-500 transition-colors">{p.name_es}</div>
              <div class="text-xs text-red-500 font-bold mt-0.5">{p.priceFrom_es}</div>
            </div>
            <span class="text-gray-300 group-hover:text-red-400 transition-colors">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white text-center py-20 px-6">
    <h2 class="text-3xl font-extrabold mb-3">¿Listo para enviar desde {c.name}?</h2>
    <p class="opacity-80 mb-8">Obtén una cotización instantánea — sin registro previo.</p>
    <a href="https://app.boxtocuba.ca/shipping-quote?lang=es" class="inline-block px-8 py-4 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors text-lg">Calcular mi tarifa →</a>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 px-6 py-12">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="font-bold text-white text-lg mb-2">Box to Cuba</div>
        <p class="text-sm">Envío confiable de paquetes desde Canadá a Cuba. La confianza de las familias desde 2020.</p>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Enlaces rápidos</div>
        <ul class="space-y-2 text-sm">
          <li><a href="/es/precios-envio-canada-cuba" class="hover:text-red-400 transition-colors">Tarifas</a></li>
          <li><a href="/es/guia-aduana-cuba" class="hover:text-red-400 transition-colors">Guía de aduana</a></li>
          <li><a href="/es/#faq" class="hover:text-red-400 transition-colors">FAQ</a></li>
          <li><a href="/es/#contacto" class="hover:text-red-400 transition-colors">Contacto</a></li>
        </ul>
      </div>
      <div>
        <div class="font-semibold text-white mb-3">Contacto</div>
        <ul class="space-y-2 text-sm">
          <li><a href="tel:+14168365517" class="hover:text-red-400 transition-colors">📞 +1 416-836-5517</a></li>
          <li><a href="mailto:info@boxtocuba.ca" class="hover:text-red-400 transition-colors">✉️ info@boxtocuba.ca</a></li>
          <li><a href="https://wa.me/14168365517" target="_blank" rel="noopener" class="hover:text-green-400 transition-colors">💬 WhatsApp</a></li>
          <li><a href="https://facebook.com/boxtocuba" target="_blank" rel="noopener" class="hover:text-blue-400 transition-colors">📘 Facebook</a></li>
          <li>📍 Toronto, Canadá</li>
        </ul>
      </div>
    </div>
    <div class="max-w-5xl mx-auto mt-10 pt-6 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <span>© 2026 Box to Cuba. Todos los derechos reservados.</span>
      <a href="/es/politica-de-privacidad/" class="hover:text-gray-300 transition-colors">Política de Privacidad</a>
    </div>
  </footer>
</BaseLayout>
