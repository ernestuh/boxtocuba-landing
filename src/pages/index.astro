---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCmsContent, t as ct } from '../lib/cms';
import { provinces as provinceData } from '../data/provinces';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm';

const lang = 'en';
const content = await getCmsContent(lang);
const t = (key: string) => ct(content, key);
---

<BaseLayout lang={lang} title={t('meta.title')} description={t('meta.description')} faqItems={t('faq.items')}>

  <Navbar lang="en" isHome={true} />


  <!-- HERO -->
  <section class="bg-gradient-to-br from-white to-red-50 px-6 py-12 md:py-20 flex flex-col md:flex-row items-center justify-center gap-8 md:gap-16 flex-wrap">
    <div class="max-w-lg">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-500 text-xs font-semibold px-4 py-2 rounded-full mb-5">{t('hero.badge')}</div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        {t('hero.headline')}
      </h1>
      <p class="text-gray-500 text-lg leading-relaxed mb-8">{t('hero.subtitle')}</p>
      <div class="flex gap-3 flex-wrap">
        <a href="https://app.boxtocuba.ca/shipping-quote" class="px-6 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-colors">{t('hero.cta_primary')}</a>
        <a href="#how-it-works" class="px-6 py-3 border border-gray-200 font-semibold rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">{t('hero.cta_secondary')}</a>
      </div>
      <div class="flex gap-5 mt-7 flex-wrap">
        <span class="text-sm text-gray-400">{t('hero.trust_1')}</span>
        <span class="text-sm text-gray-400">{t('hero.trust_2')}</span>
        <span class="text-sm text-gray-400">{t('hero.trust_3')}</span>
      </div>
    </div>
    <div class="relative flex-shrink-0">
      <img
        src="/hero-cargo.jpg"
        alt="Air cargo loading at airport"
        class="w-full max-w-md h-72 md:h-80 object-cover rounded-2xl shadow-2xl"
        width="480" height="320" loading="eager"
      />
      <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 bg-white rounded-2xl px-3 py-2 md:px-5 md:py-2.5 flex items-center gap-3 md:gap-4 shadow-lg whitespace-nowrap scale-90 md:scale-100 origin-bottom">
        <div class="flex items-center gap-1.5">
          <span class="text-xl">✈️</span>
          <div>
            <div class="text-xs font-bold text-gray-900 leading-none">Weekly flights</div>
            <div class="text-[10px] text-gray-400">Canada → Cuba</div>
          </div>
        </div>
        <div class="w-px h-8 bg-gray-200"></div>
        <div class="flex items-center gap-1.5">
          <span class="text-xl">📦</span>
          <div>
            <div class="text-xs font-bold text-gray-900 leading-none">500+ families</div>
            <div class="text-[10px] text-gray-400">served since 2020</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CITIES STRIP -->
  <section class="border-b border-gray-100 px-6 py-6 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="text-sm font-semibold text-gray-500 whitespace-nowrap">📍 Ship from your city:</div>
        <div class="flex flex-wrap gap-2 flex-1">
          {[
            { name: 'Toronto', slug: 'toronto' },
            { name: 'Montreal', slug: 'montreal' },
            { name: 'Vancouver', slug: 'vancouver' },
            { name: 'Calgary', slug: 'calgary' },
            { name: 'Ottawa', slug: 'ottawa' },
            { name: 'Edmonton', slug: 'edmonton' },
          ].map(c => (
            <a href={`/ship-from-${c.slug}-to-cuba/`}
              class="px-3 py-1.5 text-sm font-medium bg-gray-50 border border-gray-200 rounded-lg hover:border-red-400 hover:text-red-500 transition-colors">
              {c.name}
            </a>
          ))}
          <a href="/ship-from-canada-to-cuba/"
            class="px-3 py-1.5 text-sm font-semibold text-red-500 hover:underline">
            + 13 more →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DESTINATIONS STRIP -->
  <div class="bg-blue-900 text-white py-3 px-6 flex items-center justify-center gap-2 flex-wrap text-sm">
    <span class="opacity-70">{t('destinations_strip.label')}</span>
    {['La Habana', 'Varadero', 'Santa Clara', 'Holguín', 'Santiago de Cuba', '+ All provinces'].map(d => (
      <span class="bg-white/15 px-3 py-1 rounded-full text-xs font-medium">{d}</span>
    ))}
  </div>

  <!-- FEATURES -->
  <section class="bg-gray-50 px-6 py-20" id="services">
    <div class="max-w-5xl mx-auto text-center">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">{t('features.label')}</div>
      <h2 class="text-3xl font-extrabold mb-3">{t('features.title')}</h2>
      <p class="text-gray-500 max-w-xl mx-auto">{t('features.subtitle')}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
        {t('features.cards').map((card: any) => (
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all text-left">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-2xl mb-4">{card.icon}</div>
            <h3 class="font-bold mb-2">{card.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CUBA BANNER -->
  <div class="relative h-72 overflow-hidden flex items-center justify-center">
    <img
      src="https://upload.wikimedia.org/wikipedia/commons/7/70/Classic_Cuban_Cars_in_Havana%2C_Cuba.jpg"
      alt="La Habana, Cuba"
      class="absolute inset-0 w-full h-full object-cover"
      width="1200" height="288" loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-blue-900/85 to-red-500/60"></div>
    <div class="relative z-10 text-center text-white px-6">
      <h2 class="text-2xl md:text-3xl font-extrabold mb-2">{t('cuba_banner.title')}</h2>
      <p class="opacity-90 mb-6">{t('cuba_banner.subtitle')}</p>
      <div class="flex gap-10 justify-center flex-wrap">
        {[
          [t('cuba_banner.stat_1_num'), t('cuba_banner.stat_1_label')],
          [t('cuba_banner.stat_2_num'), t('cuba_banner.stat_2_label')],
          [t('cuba_banner.stat_3_num'), t('cuba_banner.stat_3_label')],
          [t('cuba_banner.stat_4_num'), t('cuba_banner.stat_4_label')],
        ].map(([num, label]) => (
          <div class="text-center">
            <div class="text-3xl font-extrabold">{num}</div>
            <div class="text-xs opacity-75 mt-1">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <section class="px-6 py-20" id="how-it-works">
    <div class="max-w-5xl mx-auto text-center">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">{t('how_it_works.label')}</div>
      <h2 class="text-3xl font-extrabold mb-3">{t('how_it_works.title')}</h2>
      <p class="text-gray-500 max-w-xl mx-auto">{t('how_it_works.subtitle')}</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
        {t('how_it_works.steps').map((step: any, i: number) => (
          <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all text-left">
            <img
              src={[
                'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=600&q=80&auto=format&fit=crop',
                'https://images.unsplash.com/photo-1553413077-190dd305871c?w=600&q=80&auto=format&fit=crop',
                'https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=600&q=80&auto=format&fit=crop',
              ][i]}
              alt={step.title}
              class="w-full h-40 object-cover"
              width="400" height="160" loading="lazy"
            />
            <div class="p-6">
              <div class="w-9 h-9 rounded-full bg-red-500 text-white text-sm font-extrabold flex items-center justify-center mx-auto mb-4">{i + 1}</div>
              <h3 class="font-bold text-center mb-2">{step.title}</h3>
              <p class="text-sm text-gray-500 text-center leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROVINCES -->
  <section class="bg-gray-50 px-6 py-20" id="destinations">
    <div class="max-w-5xl mx-auto text-center">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">{t('provinces.label')}</div>
      <h2 class="text-3xl font-extrabold mb-3">{t('provinces.title')}</h2>
      <p class="text-gray-500 max-w-xl mx-auto">{t('provinces.subtitle')}</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mt-10">
        {provinceData.map((p) => (
          <a href={`/provinces/${p.slug}/`} class="bg-white border border-gray-100 rounded-xl p-4 text-center hover:border-red-400 hover:bg-red-50 transition-all group">
            <div class="text-2xl mb-1">📦</div>
            <h4 class="text-sm font-semibold text-gray-800 group-hover:text-red-500">{p.name}</h4>
            <div class="text-xs text-red-500 font-bold mt-1">{p.priceFrom}</div>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/canada-to-cuba-shipping-rates" class="text-sm text-red-500 font-semibold hover:underline">See full shipping rates by province →</a>
      </div>
    </div>
  </section>

  <!-- QUOTE CTA -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white text-center py-20 px-6">
    <div class="text-xs font-bold text-red-300 uppercase tracking-widest mb-3">{t('quote_cta.label')}</div>
    <h2 class="text-3xl font-extrabold mb-3">{t('quote_cta.title')}</h2>
    <p class="opacity-80 mb-8">{t('quote_cta.subtitle')}</p>
    <a href="https://app.boxtocuba.ca/shipping-quote" class="inline-block px-8 py-4 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors text-lg">{t('quote_cta.cta')}</a>
  </section>

  <!-- FAQ -->
  <section class="px-6 py-20" id="faq">
    <div class="max-w-3xl mx-auto text-center">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">{t('faq.label')}</div>
      <h2 class="text-3xl font-extrabold mb-10">{t('faq.title')}</h2>
      <div class="text-left space-y-0">
        {t('faq.items').map((item: any) => (
          <details class="group border-b border-gray-100 py-5">
            <summary class="flex justify-between items-center font-semibold cursor-pointer list-none text-gray-800 hover:text-red-500 transition-colors">
              {item.q}
              <span class="text-red-500 text-xl ml-4 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-sm text-gray-500 leading-relaxed mt-3">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="bg-gray-50 px-6 py-20" id="contact">
    <div class="max-w-5xl mx-auto">
      <div class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2">{t('contact.label')}</div>
      <h2 class="text-3xl font-extrabold mb-3">{t('contact.title')}</h2>
      <p class="text-gray-500 mb-10 max-w-lg">Tell us about your shipment and we'll get back to you within a few hours.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">

        <!-- Left: contact info -->
        <div class="flex flex-col gap-4">
          {[
            ['📞', t('contact.phone_label'), t('contact.phone_value')],
            ['✉️', t('contact.email_label'), t('contact.email_value')],
            ['📍', t('contact.location_label'), t('contact.location_value')],
            ['💬', t('contact.whatsapp_label'), t('contact.whatsapp_value')],
          ].map(([icon, label, value]) => (
            <div class="flex items-center gap-4 bg-white rounded-xl px-5 py-4 shadow-sm border border-gray-100">
              <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center text-lg flex-shrink-0">{icon}</div>
              <div>
                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide">{label}</div>
                <div class="font-semibold text-gray-800 text-sm mt-0.5">{value}</div>
              </div>
            </div>
          ))}
        </div>

        <!-- Right: form card -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 md:p-8">
          <ContactForm
            client:load
            lang="en"
            apiUrl="https://lnfsqlxfzkhvptnczprc.supabase.co/functions/v1/contact-form"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-white px-6 py-12">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div>
        <img src="/logo.png" alt="Box to Cuba" class="w-12 h-12 object-contain mb-3 brightness-[10]" />
        <div class="font-bold text-lg mb-2">Box to Cuba</div>
        <p class="text-sm text-gray-400 leading-relaxed">{t('footer.tagline')}</p>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">{t('footer.quick_links')}</h4>
        <div class="space-y-2">
          <a href="https://app.boxtocuba.ca/shipping-quote" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">{t('nav.get_quote')}</a>
          <a href="https://app.boxtocuba.ca/aduana" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">{t('footer.customs_guide')}</a>
          <a href="https://app.boxtocuba.ca/client" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">{t('nav.client_portal')}</a>
          <a href="#faq" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">FAQ</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">Resources</h4>
        <div class="space-y-2">
          <a href="/canada-to-cuba-shipping-rates" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Shipping Rates</a>
          <a href="/cuba-customs-guide" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Customs Guide</a>
          <a href="/cuba-prohibited-items" class="block text-sm text-gray-400 hover:text-red-400 transition-colors">Prohibited Items</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-200 mb-4">{t('footer.contact')}</h4>
        <div class="space-y-2">
          <a href={`tel:${t('footer.phone').replace(/\s/g,'')}`} class="block text-sm text-gray-400 hover:text-red-400 transition-colors">{t('footer.phone')}</a>
          <a href={`mailto:${t('footer.email')}`} class="block text-sm text-gray-400 hover:text-red-400 transition-colors">{t('footer.email')}</a>
          <span class="block text-sm text-gray-400">{t('footer.location_1')}</span>
          <span class="block text-sm text-gray-400">{t('footer.location_2')}</span>
        </div>
      </div>
    </div>
    <div class="border-t border-gray-700 pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-gray-500">
      <span>{t('footer.rights')}</span>
      <span>{t('footer.legal')}</span>
    </div>
  </footer>

</BaseLayout>
