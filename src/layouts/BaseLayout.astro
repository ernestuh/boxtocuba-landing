---
import '../styles/global.css';

interface Props {
  lang: string;
  title: string;
  description: string;
  ogImage?: string;
  faqItems?: { q: string; a: string }[];
  alternates?: { hreflang: string; href: string }[];
}

const { lang, title, description, ogImage = '/og-image.jpg', faqItems, alternates } = Astro.props;
const canonicalURL = `https://boxtocuba.ca${Astro.url.pathname}`;
const pageTitle = title.includes('Box to Cuba') ? title : `${title} | Box to Cuba`;
const locales = ['en', 'es', 'fr'];

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Box to Cuba',
  url: 'https://boxtocuba.ca',
  telephone: '+1-416-836-5517',
  email: 'info@boxtocuba.ca',
  logo: 'https://boxtocuba.ca/logo.png',
  image: `https://boxtocuba.ca${ogImage}`,
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'CA',
    addressLocality: 'Toronto',
    addressRegion: 'ON',
  },
  areaServed: ['CA', 'CU'],
  serviceType: 'International Parcel Shipping',
  priceRange: '$$',
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang -->
    {alternates ? (
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    ) : (
      <>
        {locales.map((l) => (
          <link
            rel="alternate"
            hreflang={l}
            href={`https://boxtocuba.ca${l === 'en' ? '' : `/${l}`}/`}
          />
        ))}
        <link rel="alternate" hreflang="x-default" href="https://boxtocuba.ca/" />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://boxtocuba.ca${ogImage}`} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : lang === 'es' ? 'es_ES' : 'fr_FR'} />
    <meta property="og:site_name" content="Box to Cuba" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://boxtocuba.ca${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EJ3Z9QRV9F"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EJ3Z9QRV9F');
    </script>

    <!-- JSON-LD: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />

    <!-- JSON-LD: FAQPage (rich snippets) -->
    {faqItems && faqItems.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems.map((item: { q: string; a: string }) => ({
          '@type': 'Question',
          name: item.q,
          acceptedAnswer: { '@type': 'Answer', text: item.a }
        }))
      })} />
    )}
  </head>
  <body>
    <slot />
    <!-- Cookie consent banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-gray-900 border-t-4 border-red-500 text-white px-6 py-5 shadow-2xl">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-sm text-gray-300 leading-relaxed">
          {lang === 'es'
            ? <span>En nuestro sitio web <strong class="text-white">boxtocuba.ca</strong> usamos cookies para garantizar el correcto funcionamiento de la página y mejorar tu experiencia. Si decides continuar navegando, entendemos que aceptas nuestra política de cookies incluida en nuestra <a href="/es/politica-de-privacidad/" class="text-red-400 hover:text-red-300 underline transition-colors">Política de Privacidad</a>.</span>
            : lang === 'fr'
            ? <span>Sur notre site <strong class="text-white">boxtocuba.ca</strong>, nous utilisons des cookies pour assurer le bon fonctionnement de la page et améliorer votre expérience. En continuant à naviguer, vous acceptez notre politique de cookies incluse dans notre <a href="/fr/politique-de-confidentialite/" class="text-red-400 hover:text-red-300 underline transition-colors">Politique de confidentialité</a>.</span>
            : <span>On our website <strong class="text-white">boxtocuba.ca</strong>, we use cookies to ensure the correct functioning of this page and to improve your experience. If you decide to continue browsing, we understand that you accept the cookies policy included in our <a href="/privacy-policy/" class="text-red-400 hover:text-red-300 underline transition-colors">Privacy Policy</a>.</span>
          }
        </p>
        <button id="cookie-close" aria-label="Close"
          class="shrink-0 px-5 py-2 text-sm font-semibold bg-red-500 hover:bg-red-600 text-white rounded-lg transition-colors whitespace-nowrap">
          {lang === 'es' ? 'Entendido' : lang === 'fr' ? 'Compris' : 'Got it'}
        </button>
      </div>
    </div>

    <script is:inline>
      (function() {
        var banner = document.getElementById('cookie-banner');
        if (!banner) return;
        if (localStorage.getItem('btc_cookie_consent')) {
          banner.style.display = 'none';
        }
        var btn = document.getElementById('cookie-close');
        if (btn) {
          btn.addEventListener('click', function() {
            localStorage.setItem('btc_cookie_consent', 'accepted');
            banner.style.display = 'none';
          });
        }
      })();
    </script>

    <!-- Floating WhatsApp button -->
    <a href="https://wa.me/14168365517" target="_blank" rel="noopener noreferrer"
      aria-label="Contact us on WhatsApp"
      class="fixed bottom-20 right-5 z-50 w-14 h-14 bg-green-500 hover:bg-green-600 rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-7 h-7">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.529 5.858L.057 23.882a.5.5 0 0 0 .61.61l6.101-1.459A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.667-.523-5.183-1.433l-.371-.22-3.844.919.937-3.77-.242-.389A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
      </svg>
    </a>
  </body>
</html>
